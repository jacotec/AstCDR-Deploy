# Secrets for ${ENV} interpolation in config.yaml.
# Copy to .env and fill in. .env does NOT belong in version control.

# Host port of the web UI (Docker port mapping, default 3000, bind 0.0.0.0).
# The (TLS) reverse proxy talks to this port.
WEB_PORT=3000

# Optional: pin a fixed image version (default is :latest -> auto-updates on pull).
# CDRJ_IMAGE=ghcr.io/jacotec/astcdr:1.0.0

# Session signature (e.g. `openssl rand -hex 32`)
APP_SECRET_KEY=

# FreePBX source (read-only user, see QUICKSTART.md step 1)
SOURCE_DB_PASSWORD=

# Postgres cache
CACHE_DB_PASSWORD=

# OIDC (Authentik/Keycloak/Nextcloud)
OIDC_CLIENT_SECRET=

# SMTP for warning emails (optional — only needed if you enable the `email` block in
# config.yaml). Leave BOTH empty for relays that don't require authentication.
SMTP_USER=
SMTP_PASS=

# Break-glass local admin: do NOT put the bcrypt hash here!
# bcrypt hashes contain '$', which Docker Compose interprets as variables in .env
# and destroys the hash. Put the hash RAW into config.yaml instead, under
# auth.local.users[].password_hash.
# Generate:  docker compose run --rm cdrj-web python -m app.auth.local "mypassword"
